{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": "./",
    "composite": true,
    "declaration": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "incremental": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "noEmit": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "jsx": "react"
  },
  "exclude": ["node_modules", "lib"],
  "include": [
    "ambient.d.ts",
    "index.d.cts",
    "index.d.mts",
    "index.js",
    "src",
    "test",
    "**/*.json"
  ]
}
